FROM python:3.12-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Install python dependencies
RUN pip install --no-cache-dir httpx uvicorn mcp fastmcp

# Copy the API script
COPY company_api_mcp.py .

# Expose port and run the app
EXPOSE 8080
CMD ["python", "company_api_mcp.py"]
